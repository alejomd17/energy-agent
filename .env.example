# =============================================================================
# Copiar este archivo a .env y completar los valores reales.
# NUNCA subir .env al repositorio.
# =============================================================================

# --- App ---
DEBUG=false

# --- Supabase (PostgreSQL + pgvector) ---
# Obtenidos en: https://app.supabase.com → Project Settings → API
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>
# Obtenido en: Project Settings → Database → Database password
SUPABASE_DB_PASSWORD=<database-password>

# --- MongoDB Atlas ---
# Formato: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# --- Google Gemini (solo para embeddings RAG) ---
# Obtenido en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<gemini-api-key>

# --- Groq (LLM para agentes) ---
# Obtenido en: https://console.groq.com/keys
GROQ_API_KEY=<groq-api-key>
# Modelos: llama-3.3-70b-versatile (default), llama3-8b-8192, mixtral-8x7b-32768
GROQ_MODEL=llama-3.3-70b-versatile

# --- LangSmith (opcional — trazabilidad de agentes) ---
# Obtenido en: https://smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=energy-agent
